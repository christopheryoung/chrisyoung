@InCollection{	  osborne2000,
  author	= {Osborne, Catherine},
  title		= {Aristotle on the Fantastic Abilities of Animals in De
		  Anima 3.3},
  booktitle	= {Oxford Studies in Ancient Philosophy},
  publisher	= {Oxford Univ Pr},
  year		= {2000},
  pages		= { 253--285},
  abstract	= {Phantasia provides the mechanism whereby objects perceived
		  can also be objects recalled, imagined, dreamt or thought,
		  thereby avoiding a Platonic two-world epistemology and
		  ensuring continuity between human and animal experience.
		  But De anima 3.3 offers no formal theory of phantasia, it
		  merely distinguishes it from two adjacent phenomena
		  (perception and thought) by mentioning factors that fail to
		  fit. The factors differ with the contrast being drawn, and
		  detail functions typical but not definitive of
		  phantasia--which emerges as a capacity to absorb and recall
		  forms once perceived, providing a resource for manifold
		  cognitive faculties in animals and humans.},
