@Article{	  jorba2016review,
  author	= {Jorba, Marta},
  title		= {Semantic Perception: How the Illusion of a Common Language
		  Arises and Persists , by Jody Azzouni.},
  journal	= {Mind},
  volume	= {125},
  number	= {497},
  pages		= {290-297},
  year		= {2016},
  month		= {01},
  abstract	= { Language understanding, communication, and meaning have
		  been central topics in the history of philosophy and are
		  key issues in several fields of contemporary philosophy,
		  specially philosophy of language. The book Semantic
		  Perception contributes to this broad literature by
		  approaching language transactions in communication from the
		  promising point of view of the experience of language
		  understanding. Jody Azzouni’s main objective in the book
		  is to delineate a phenomenology of language understanding,
		  which is in turn an alternative approach to extant accounts
		  of language understanding and meaning such as the Gricean
		  and neo-Gricean programs. The book is well-structured,
		  provides deep and detailed philosophical analysis, and
		  covers a wide range of topics within philosophy of language
		  and mind; it also presents clear and strong methodological
		  views and implications for theorizing on semantics. },
  issn		= {0026-4423},
  doi		= {10.1093/mind/fzv163},
  url		= {https://doi.org/10.1093/mind/fzv163},
