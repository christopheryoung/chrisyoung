@Article{	  jeppsson2022strategies,
  author	= {Jeppsson, Sofia M I},
  title		= "{My Strategies for Dealing With Radical Psychotic Doubt: A
		  Schizo-Something Philosopher’s Tale}",
  journal	= {Schizophrenia Bulletin},
  year		= {2022},
  month		= {06},
  abstract	= "{I am a 45-year-old Swedish philosopher with
		  “schizo-something”: I have never been given a precise
		  diagnostic label, but a psychiatrist once said that
		  although I do not tick enough boxes for schizophrenia, I am
		  somewhere in the ballpark.I could fill a book with all the
		  odd experiences and issues I have had, but let us keep it
		  short: The world I inhabit is not very firm. It is flimsy,
		  and occasionally flutters and falls apart, as if someone
		  tore down the painted backdrop at the scene to expose what
		  lies behind: a dangerous place where everything is slightly
		  off, skewed, two-dimensional and washed-out , and full of
		  murderous demons. The mainstream world can grow back up
		  over the demon world again, covering it, until the next
		  time it falls apart. Sometimes it does not fall apart, but
		  remains thin enough to be translucent.}",
  issn		= {0586-7614},
  doi		= {10.1093/schbul/sbac074},
  url		= {https://doi.org/10.1093/schbul/sbac074},
